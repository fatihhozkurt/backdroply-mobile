{
  "name": "backdroply-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "doctor": "npx expo-doctor",
    "prebuild:android": "expo prebuild --platform android",
    "build:android:release": "cross-env NODE_ENV=production expo prebuild --platform android && node scripts/ensureAndroidSdk.js && cd android && gradlew.bat --no-daemon assembleRelease"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "expo": "~55.0.6",
    "expo-auth-session": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-secure-store": "~55.0.8",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-web": "0.21.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
