{
  "expo": {
    "name": "Backdroply",
    "slug": "backdroply",
    "version": "1.0.0",
    "scheme": "backdroply",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#030712"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fatihozkurt.backdroply"
    },
    "android": {
      "package": "com.fatihozkurt.backdroply",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#030712"
      }
    },
    "extra": {
      "apiBaseUrl": "http://localhost:8080/api/v1",
      "googleWebClientId": "",
      "googleAndroidClientId": "",
      "googleIosClientId": ""
    }
  }
}
